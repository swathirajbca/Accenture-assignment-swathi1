 FIND OPERATIONS

db.products.find()

db.products.find().pretty()

db.products.findOne({ name: "iPhone 14" })

db.products.find({ category: "Electronics" })

db.products.find({ price: { $lt: 5000 } })

db.products.find({ price: { $lte: 5000 } })

db.products.find({ price: { $gt: 5000 } })

db.products.find({ price: { $gte: 5000 } })

db.products.find({ price: { $ne: 5000 } })

db.products.find({ price: { $in: [1000,2000,5000] } })

db.products.find({ price: { $nin: [1000,2000,5000] } })

db.products.find({
   $and: [
      { category: "Electronics" },
      { price: 5000 }
   ]
})

db.products.find({
   $or: [
      { category: "Electronics" },
      { brand: "Apple" }
   ]
})

db.products.find({
   $or: [
      { price: { $gt: 5000 } },
      { brand: "Samsung" }
   ]
})

db.products.find({
   price: {
      $gte: 5000,
      $lte: 20000
   }
})

db.products.find({
   price: {
      $not: { $gt: 5000 }
   }
})

UPDATE OPERATIONS

db.products.updateOne(
   { name: "iPhone 14" },
   { $set: { name: "iPhone 14 Pro" } }
)

db.products.updateMany(
   { price: { $lt: 5000 } },
   { $set: { stock: 100 } }
)

db.products.updateOne(
   { brand: "Nike" },
   { $set: { price: 5500 } }
)

db.products.updateMany(
   { category: "Electronics" },
   { $set: { stock: 200 } }
)

db.products.replaceOne(
   { name: "Office Chair" },
   {
      name: "Gaming Chair",
      category: "Furniture",
      price: 12000,
      stock: 10,
      brand: "GreenSoul"
   }
)

